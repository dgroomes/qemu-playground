#cloud-config
hostname: qemu-hello
bootcmd:
  - [ mkdir, -p, /mnt/qemu-host ]
  - [ mount, -t, 9p, -o, 'trans=virtio,version=9p2000.L', qemu_host, /mnt/qemu-host ]
runcmd:
  - [ sh, -c, '/mnt/qemu-host/hello-world.sh | tee /dev/console /mnt/qemu-host/hello-output.txt' ]
final_message: "cloud-init finished the qemu-playground hello-world demo"
power_state:
  delay: now
  mode: poweroff
  message: qemu-playground hello-world demo finished
  timeout: 30
  condition: true
